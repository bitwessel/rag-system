# ── LLM / Embedding source ─────────────────────────────────────────────────────
# Set both to "ollama" to run fully locally (no API key needed).
# Set to "openrouter" (default) to use cloud models.
LLM_SOURCE=ollama
EMBED_SOURCE=ollama

# ── Ollama (used when LLM_SOURCE=ollama or EMBED_SOURCE=ollama) ────────────────
# Install Ollama: https://ollama.com  — then run:
#   ollama pull llama3.2          (LLM, ~2 GB)
#   ollama pull nomic-embed-text  (embeddings, ~274 MB)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── OpenRouter (used when LLM_SOURCE=openrouter or EMBED_SOURCE=openrouter) ────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Vector backend: chroma | pinecone | weaviate
VECTOR_BACKEND=chroma

# ChromaDB persistent directory
CHROMA_PERSIST_DIR=./data/chroma

# Models (used when source=openrouter, override if needed)
# Good balance: anthropic/claude-sonnet-4-6
# Cheaper/faster: anthropic/claude-haiku-4-5
# Higher-end: anthropic/claude-opus-4-7
DEFAULT_LLM_MODEL=anthropic/claude-sonnet-4-6
DEFAULT_EMBED_MODEL=openai/text-embedding-3-large
DEFAULT_MULTIMODAL_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# OpenRouter attribution headers (optional but recommended)
OPENROUTER_HTTP_REFERER=https://github.com/BitWessel/rag-system
OPENROUTER_X_TITLE=rag-system

# IMAP (optional — only needed if you use `ingest email --imap`)
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# Pinecone (stub, fill in if you switch VECTOR_BACKEND=pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=

# Weaviate (stub, fill in if you switch VECTOR_BACKEND=weaviate)
WEAVIATE_URL=
WEAVIATE_API_KEY=
